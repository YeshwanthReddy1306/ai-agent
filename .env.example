# ===== REQUIRED — the only key needed for the web console =====
# Free API key with free credits: https://dashboard.sarvam.ai
SARVAM_API_KEY=

# ===== Optional tuning =====
PORT=3100
# sarvam-30b = fastest (best for live calls) | sarvam-105b = highest quality
LLM_MODEL=sarvam-30b
# saaras:v3 (23 languages, recommended) | saarika:v2.5 (legacy)
STT_MODEL=saaras:v3
# bulbul:v3 voices: kavitha, roopa, shruti, priya, neha, kavya, tanya (female) / aditya, rahul, vijay, gokul, mani (male)
AGENT_VOICE=kavitha
# hard cap per call before the agent wraps up warmly
MAX_CALL_MINUTES=6
# DPDP hygiene: purge call summaries older than this on server start
RETENTION_DAYS=90

# ===== Phase 2 — real phone calls (telephony/bridge.js, needs: npm i ws) =====
TELEPHONY_PORT=3200
# public tunnel to this machine, e.g. from: ngrok http 3200
PUBLIC_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# your Twilio number in E.164, e.g. +1... or +91...
TWILIO_FROM_NUMBER=
