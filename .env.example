# Get a free API key (with free credits) at https://dashboard.sarvam.ai
SARVAM_API_KEY=

# Optional overrides
PORT=3100
# sarvam-30b = fastest (best for live calls) | sarvam-105b = highest quality
LLM_MODEL=sarvam-30b
# bulbul:v3 speakers: kavitha, roopa, shruti, priya, neha, ritu, kavya, tanya (female) / aditya, rahul, vijay, gokul, mani (male)
AGENT_VOICE=kavitha
